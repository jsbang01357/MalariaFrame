{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "malariaframe-gcs-proxy",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-11",
  "routes": [
    {
      "pattern": "malaria.jisong.dev",
      "custom_domain": true
    }
  ],
  "vars": {
    "ORIGIN": "https://storage.googleapis.com/malariaframe-jisong-dev"
  },
  "observability": {
    "enabled": true
  }
}
